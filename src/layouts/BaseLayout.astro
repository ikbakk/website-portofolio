---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import '../styles/motion.css';
import Topbar from '../components/Topbar.astro';
import { navItems, profile } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  showChrome?: boolean;
}
const {
  title = `${profile.name} · Frontend engineer`,
  description = 'Frontend engineer portfolio built in Astro, Tailwind CSS, and GSAP.',
  showChrome = true,
} = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="wechat">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ededed" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to main content</a>
      <div id="smooth-wrapper">
        <div id="smooth-content">
          {showChrome && <Topbar profile={profile} navItems={navItems} transition:persist />}
          <slot />
      </div>
    </div>
    <script>
      import { initMotion } from '../scripts/main';
      initMotion();
    </script>
  </body>
</html>
