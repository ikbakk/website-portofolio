---
import { ClientRouter } from "astro:transitions";
import "@/styles/global.css";

import { profile } from "@/data/profile";
import { seo } from "@/data/seo";
import type { NavFolio } from "@/data/nav";

import Topbar from "@/components/Topbar.astro";
import Spine from "@/components/Spine.astro";
import SkipLink from "@/components/SkipLink.astro";

interface Props {
  currentSection: NavFolio;
  homeHref: string;
  asAnchors?: boolean;
  title?: string;
  description?: string;
}

const {
  currentSection,
  homeHref,
  asAnchors = true,
  title = seo.title,
  description = seo.description,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(seo.ogImage, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={seo.themeColor} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content={seo.themeColorDark} media="(prefers-color-scheme: dark)" />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={profile.name} />

    <meta name="twitter:card" content={seo.twitter.card} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <ClientRouter fallback="swap" />
  </head>
  <body data-spine-anchors={asAnchors ? "true" : "false"}>
    <SkipLink href="#main" label="Skip to main content" />
    <Topbar
      profile={profile}
      currentSection={currentSection}
      homeHref={homeHref}
    />
    <Spine currentId={currentSection.id} asAnchors={asAnchors} />

    <div id="smooth-wrapper" class="shell ">
      <main id="smooth-content" class="pages" data-od-id="pages">
        <slot />
      </main>
    </div>

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import { ScrollSmoother } from "gsap/ScrollSmoother";
      import { destroySectionProgress, initSectionProgress } from "@/lib/section-progress";

      gsap.registerPlugin(ScrollTrigger, ScrollSmoother);

      document.addEventListener("astro:page-load", () => {
        ScrollSmoother.get()?.kill();
        ScrollSmoother.create({
          wrapper: "#smooth-wrapper",
          content: "#smooth-content",
          smooth: 1.5,
          effects: true,
          normalizeScroll: true,
        });
        initSectionProgress();
      });

      document.addEventListener("astro:before-swap", () => {
        destroySectionProgress();
        ScrollSmoother.get()?.kill();
      });
    </script>
  </body>
</html>
