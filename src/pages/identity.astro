---
/**
 * /identity  -  4 mark directions deck.
 *
 * One page, four directions. The original artifact used a left rail
 * with the title and routes; this Astro version uses a topbar-style
 * header for navigation since the chrome (topbar, spine, tweaks)
 * is already on the page.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { profile } from "@/data/profile";
import { marks } from "@/data/marks";
import { identityFolio } from "@/data/nav";
import Mark from "@/components/Mark.astro";
import FolioBar from "@/components/FolioBar.astro";
import FolioNumber from "@/components/FolioNumber.astro";

const currentSection = identityFolio;
const wordmarkName = profile.name;
const wordmarkRole = profile.role;
const monogram = profile.monogram;

// The pre/code blocks on the Apply page. Kept here so curly braces
// and other Astro-template-meaningful characters never get parsed.
const applyHtml = `<a class="topbar-mark" href="/" aria-label="Home">
  <svg class="mark mark-a">...</svg>
  <svg class="mark mark-b">...</svg>
  <svg class="mark mark-c">...</svg>
  <svg class="mark mark-d">...</svg>
</a>`;
const applyCss = `.mark { display: none; width: 24px; height: 24px; }
body[data-direction="a"] .mark-a { display: block; }
body[data-direction="b"] .mark-b { display: block; }
body[data-direction="c"] .mark-c { display: block; }
body[data-direction="d"] .mark-d { display: block; }`;
const applyJs = `// Tweak panel: cycle directions
document.querySelectorAll('[data-set-direction]')
  .forEach(b => b.addEventListener('click', () => {
    document.body.dataset.direction = b.dataset.setDirection;
  }));`;
const applyPersist = `// Optional: remember the pick
localStorage.setItem(
  'mark-direction',
  document.body.dataset.direction
);`;
---

<BaseLayout
  currentSection={currentSection}
  homeHref="/"
  asAnchors={false}
  title="Identity system / [Your name]"
  description="Four directions for a frontend engineer's personal brand, bound to the WeChat design system. Live SVG, no raster mockups."
>
  <article class="page" id="page-01" data-od-id="identity-brief">
    <FolioBar
      folioNumber="00"
      folioTag="Identity system / v0.1"
      folioMeta="four directions, one system"
      folioId="folio-identity-brief"
    />
    <div class="page-inner">
      <FolioNumber text="00 / identity" />
      <h1 class="identity-title" data-od-reveal="entry">
        Field <em>notes</em>
      </h1>
      <p class="identity-sub" data-od-reveal="entry">
        Four directions for a frontend engineer's personal brand, bound to the WeChat
        design system. Live SVG, no raster mockups.
      </p>

      <div class="identity-grid">
        <div class="identity-stack" data-od-reveal="entry">
          <p>
            Every direction uses the same six tokens (<code class="code-tag">--bg / --surface / --fg / --muted / --border / --accent</code>),
            the same Newsreader + IBM Plex Sans + JetBrains Mono stack, and the same six
            spacing tiers. They differ in silhouette: how much the mark carries versus
            how much the typography carries.
          </p>
          <p>
            A is the safest reading. C is the most editorial. B is the most original.
            D is the most communicative. Pick the one that matches the way you want to
            be remembered.
          </p>
        </div>
        <aside class="identity-meta" data-od-reveal="entry">
          <strong>Constraints</strong><br />
          No em dashes. No Tailwind. No fabricated metrics. No external image CDNs. The
          mark must render without webfonts (system fallbacks present) and degrade
          gracefully in print.
          <br /><br />
          <strong>Deliverables per route</strong><br />
          Symbol (SVG) / Wordmark (HTML) / Lockup (HTML composition) / Palette swatches /
          Usage rules (do + don't) / Generation prompt (raster-ready).
        </aside>
      </div>

      <div class="showcase" aria-label="All four marks at thumbnail size" data-od-reveal="entry">
        {marks.map((mark) => (
          <a class="showcase-tile" href={`#direction-${mark.id}`}>
            <Mark mark={mark} size={48} monogram={monogram} labelled={false} />
            <div class="showcase-tile-label">{mark.id.toUpperCase()} / {mark.name}</div>
          </a>
        ))}
      </div>
    </div>
  </article>

  {marks.map((mark) => (
    <article class="page" id={`page-${mark.id === 'a' ? '02' : mark.id === 'b' ? '03' : mark.id === 'c' ? '04' : '05'}`} data-od-id={`identity-direction-${mark.id}`}>
      <FolioBar
        folioNumber={mark.id.toUpperCase()}
        folioTag={`${mark.id.toUpperCase()} / ${mark.name}`}
        folioMeta={mark.tagline.split(" / ")[0]}
        folioId={`folio-identity-${mark.id}`}
      />
      <div class="page-inner">
        <FolioNumber text={`${mark.id.toUpperCase()} / ${mark.name.toLowerCase()}`} />
        <div class="direction">
          <header class="direction-head" data-od-reveal="entry">
            <div class="direction-no">{mark.id.toUpperCase()}</div>
            <div>
              <h2 class="direction-name">{mark.name}</h2>
              <p class="direction-tag">{mark.tagline}</p>
            </div>
          </header>

          <div class="stage" data-od-reveal="entry">
            <div class="stage-cell">
              <div class="stage-label">Symbol</div>
              <Mark mark={mark} size={192} monogram={monogram} labelled={true} />
            </div>
            <div class="stage-cell">
              <div class="stage-label">Lockup</div>
              <div class="lockup">
                <Mark mark={mark} size={48} monogram={monogram} labelled={false} />
                <div class="wordmark">
                  <span class="wordmark-name">{wordmarkName}</span>
                  <span class="wordmark-role">{wordmarkRole}</span>
                </div>
              </div>
            </div>
          </div>

          <div class="grid-3" data-od-reveal="entry">
            <div>
              <p class="col-label">Palette</p>
              <div class="col-body">
                <div class="swatches">
                  {mark.palette.map((swatch) => (
                    <div class="swatch">
                      <div
                        class="swatch-chip"
                        data-token={swatch.token}
                        data-bordered={swatch.bordered ? "true" : undefined}
                      ></div>
                      <span class="swatch-name">{swatch.token}</span>
                      <span class="swatch-hex">{swatch.token}</span>
                    </div>
                  ))}
                </div>
                <p>{mark.description}</p>
              </div>
            </div>
            <div>
              <p class="col-label">Usage rules</p>
              <ul class="rules">
                <li class="rule rule-do"><span class="rule-mark">+</span><span>Use as the favicon / the silhouette holds at 16px.</span></li>
                <li class="rule rule-do"><span class="rule-mark">+</span><span>Use on the social-card avatar paired with the bg.</span></li>
                <li class="rule rule-dont"><span class="rule-mark">−</span><span>Don't recolor the mark outside the swatch list.</span></li>
                <li class="rule rule-dont"><span class="rule-mark">−</span><span>Don't add a stroke that wasn't in the original.</span></li>
              </ul>
            </div>
            <div>
              <p class="col-label">Raster prompt</p>
              <div class="prompt-meta">
                <span>{mark.model} / {mark.aspect}</span>
                <span>copy &amp; run</span>
              </div>
              <div class="prompt">{mark.prompt}</div>
            </div>
          </div>
        </div>
      </div>
    </article>
  ))}

  <article class="page" id="page-06" data-od-id="identity-apply">
    <FolioBar
      folioNumber="+"
      folioTag="+ / Apply"
      folioMeta="integration receipt"
      folioId="folio-identity-apply"
    />
    <div class="page-inner">
      <FolioNumber text="+ / apply" />
      <h2 class="page-title" data-od-reveal="entry">Drop the mark into the <em>portfolio</em>.</h2>
      <p class="page-lede" data-od-reveal="entry">
        All four marks are pure SVG. The same four files are inlined in the topbar
        with a live direction-switcher (<code class="code-tag">body[data-direction]</code>).
        The copy here is the integration receipt.
      </p>

      <div class="apply" data-od-reveal="entry">
        <div class="apply-grid">
          <div>
            <p class="col-label">HTML</p>
            <pre set:html={applyHtml}></pre>
          </div>
          <div>
            <p class="col-label">CSS</p>
            <pre set:html={applyCss}></pre>
          </div>
          <div>
            <p class="col-label">JS</p>
            <pre set:html={applyJs}></pre>
          </div>
          <div>
            <p class="col-label">Persistence</p>
            <pre set:html={applyPersist}></pre>
          </div>
        </div>
      </div>

      <div class="section-spacer" data-od-reveal="entry">
        <p class="col-label">Open TODOs (waiting on real inputs)</p>
        <ul class="rules">
          <li class="rule rule-do"><span class="rule-mark">→</span><span>Replace <code class="code-tag">[Your name]</code> across all four directions and the portfolio rail.</span></li>
          <li class="rule rule-do"><span class="rule-mark">→</span><span>Decide whether the monogram letter follows your initial, your company's initial, or a deliberately different glyph (we used <em>{monogram}</em> as a placeholder).</span></li>
          <li class="rule rule-do"><span class="rule-mark">→</span><span>Pick a direction and set <code class="code-tag">body[data-direction]</code> as the default; remove the others if you don't want the Tweaks control visible.</span></li>
          <li class="rule rule-do"><span class="rule-mark">→</span><span>When an image-provider credential lands, run the four prompts above through the image model and stash the PNGs as <code class="code-tag">public/marks/&lt;direction&gt;.png</code> for OG cards and the resume header.</span></li>
        </ul>
      </div>
    </div>
  </article>
</BaseLayout>
