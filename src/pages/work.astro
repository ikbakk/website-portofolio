---
/**
 * /work  -  page-02 Selected work.
 *
 * Three ProjectEntry components, each with a screenshot slot. The
 * long-form markdown body comes from the Astro content collection
 * (src/content/projects/0X.md) and is rendered through the default
 * slot of each ProjectEntry.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import Folio from "@/components/Folio.astro";
import ProjectEntry from "@/components/ProjectEntry.astro";
import { folios } from "@/data/nav";
import { projects, projectsFolioTag, projectsFolioMeta, projectsLede } from "@/data/projects";
import { getCollection, render } from "astro:content";

const currentSection = folios[1];

// Look up each project's markdown body in the content collection.
const collection = await getCollection("projects");
const entryContents = new Map(
  await Promise.all(
    collection.map(async (entry) => [entry.id, await render(entry)]),
  ),
);
---

<BaseLayout currentSection={currentSection} homeHref="/">
  <Folio
    folioNumber="02 / selected work"
    folioBarNumber="02"
    folioBarTag={projectsFolioTag}
    folioBarMeta={projectsFolioMeta}
    folioBarId="folio-02"
    folioBarH2="Selected work: three projects, 2023 to 2026"
    id="page-02"
    odId="page-02-work"
  >
    <p class="page-lede" data-od-id="work-lede" data-od-reveal="entry">
      {projectsLede}
    </p>

    <div class="entries">
      {projects.map((summary) => {
        const body = entryContents.get(summary.slug);
        return (
          <ProjectEntry entry={summary}>
            {body && <body.Content />}
          </ProjectEntry>
        );
      })}
    </div>
  </Folio>
</BaseLayout>
