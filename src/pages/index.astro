---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Folio from "@/components/Folio.astro";
import ProjectEntry from "@/components/ProjectEntry.astro";
import ToolkitItem from "@/components/ToolkitItem.astro";
import ContactRow from "@/components/ContactRow.astro";
import Colophon from "@/components/Colophon.astro";
import { folios } from "@/data/nav";
import { hero } from "@/data/hero";
import { projects, projectsFolioTag, projectsFolioMeta, projectsLede } from "@/data/projects";
import { toolkit, toolkitFolioTag, toolkitFolioMeta, toolkitLede } from "@/data/toolkit";
import { approach } from "@/data/approach";
import { contact, contactFolioTag, contactFolioMeta, contactLede } from "@/data/contact";
import { colophon as colophonData } from "@/data/colophon";
import { seo } from "@/data/seo";
import { getCollection } from "astro:content";

// The current section is field-note on first paint; scroll-spy in
// src/scripts/scroll-spy.ts (wired in BaseLayout) updates it.
const currentSection = folios[0];

// Look up each project's markdown body in the content collection.
const collection = await getCollection("projects");
const entryBodies = new Map(collection.map((entry) => [entry.id, entry]));
---

<BaseLayout
  currentSection={currentSection}
  homeHref="#field-note"
  asAnchors={true}
  title={seo.title}
  description={seo.description}
>
  <Folio
    sectionNumber="01 / field note"
    sectionBarNumber="01"
    sectionBarTag={hero.folioTag}
    sectionBarMeta={hero.folioMeta}
    sectionBarId="section-01"
    id="field-note"
    odId="field-note-hero"
  >
    <h1 class="hero-title" data-od-id="hero-title" data-od-reveal="entry">
      {hero.title.map((seg) =>
        typeof seg === "string" ? seg : <em>{seg.em}</em>,
      )}
    </h1>

    <div class="hero-summary">
      <p data-od-id="hero-subhead" data-od-reveal="entry">
        {hero.lede}
      </p>
      <aside
        class="hero-facts"
        aria-label="At a glance"
        data-od-id="hero-facts"
        data-od-reveal="entry"
      >
        {hero.marginalia.map((row) => (
          <p>
            <span class="fact-label">{row.label}</span>
            {row.live ? (
              <span class="js-local-slot">{row.value}</span>
            ) : (
              row.value
            )}
          </p>
        ))}
      </aside>
    </div>
  </Folio>

  <Folio
    sectionNumber="02 / selected work"
    sectionBarNumber="02"
    sectionBarTag={projectsFolioTag}
    sectionBarMeta={projectsFolioMeta}
    sectionBarId="section-02"
    sectionBarH2="Selected work: four projects, 2024 to 2026"
    id="selected-work"
    odId="selected-work"
  >
    <p class="page-intro" data-od-id="work-lede" data-od-reveal="entry">
      {projectsLede}
    </p>

    <div class="project-list">
      {projects.map((summary) => {
        const entry = entryBodies.get(summary.slug);
        return <ProjectEntry entry={summary} />;
      })}
    </div>
  </Folio>

  <Folio
    sectionNumber="03 / toolkit"
    sectionBarNumber="03"
    sectionBarTag={toolkitFolioTag}
    sectionBarMeta={toolkitFolioMeta}
    sectionBarId="section-03"
    sectionBarH2="Toolkit: the kinds of work I do, in my own words"
    id="toolkit"
    odId="toolkit"
  >
    <p class="page-intro" data-od-id="toolkit-lede" data-od-reveal="entry">
      {toolkitLede}
    </p>

    <ol class="toolkit">
      {toolkit.map((item, i) => (
        <ToolkitItem item={item} index={i} />
      ))}
    </ol>
  </Folio>

  <Folio
    sectionNumber="04 / approach"
    sectionBarNumber="04"
    sectionBarTag={approach.folioTag}
    sectionBarMeta={approach.folioMeta}
    sectionBarId="section-04"
    sectionBarH2="Approach: how I work, briefly"
    id="approach"
    odId="approach"
  >
    <div class="approach">
      <div class="approach-side" data-od-id="approach-side" data-od-reveal="entry">
        {approach.side}
      </div>
      <div class="approach-body">
        <p data-od-id="approach-lede" data-od-reveal="entry">
          {approach.paragraphs[0]}
        </p>
        {approach.paragraphs.slice(1).map((para) => (
          <p data-od-reveal="entry">{para}</p>
        ))}
        <ul class="approach-list" data-od-id="approach-list" data-od-reveal="entry">
          {approach.list.map((row) => (
            <li>
              <span>{row.label}</span>
              <span>{row.value}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Folio>

  <Folio
    sectionNumber="05 / contact"
    sectionBarNumber="05"
    sectionBarTag={contactFolioTag}
    sectionBarMeta={contactFolioMeta}
    sectionBarId="section-05"
    sectionBarH2="Contact: reply window 1 to 2 business days"
    id="contact"
    odId="contact"
  >
    <p class="page-intro" data-od-id="contact-lede" data-od-reveal="entry">
      {contactLede}
    </p>
    <ul class="contact-list" data-od-id="contact-list">
      {contact.map((row) => <ContactRow row={row} />)}
    </ul>
  </Folio>

  <Colophon data={colophonData} />
</BaseLayout>

