---
import Mark from './Mark.astro';
import type { navItems as navItemsData, profile as profileData } from '../data/site';

type NavItem = (typeof navItemsData)[number];
type Profile = typeof profileData;

const { profile, navItems } = Astro.props as { profile: Profile; navItems: readonly NavItem[] };
---
<header class="topbar" data-motion="topbar">
  <a class="topbar-brand" href="#field" aria-label={`${profile.name} home`}>
    <Mark size="sm" />
    <span class="brand-copy">
      <strong>{profile.name}</strong>
      <span>{profile.role}</span>
    </span>
  </a>
  <div class="topbar-status" aria-live="polite">
    <span class="status-dot" aria-hidden="true"></span>
    <span>{profile.status}</span>
  </div>
  <nav class="topbar-nav" aria-label="Primary navigation">
    {navItems.map((item) => <a href={item.href} data-nav-target={item.id}>{item.number}<span>{item.label}</span></a>)}
  </nav>
  <span class="topbar-progress" aria-hidden="true"><span></span></span>
</header>
