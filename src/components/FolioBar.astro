---
/**
 * FolioBar. The sticky strip immediately under the topbar that names
 * the current section. Has a visually-hidden h2 for the page landmark.
 *
 *  sectionNumber   -  the printed "01" / "02" etc.
 *  sectionTag      -  the printed "01 / Field note" tag
 *  sectionMeta     -  the printed "2026 / present" or "three projects, ..."
 *  h2Label       -  the screen-reader-only h2 text. Optional.
 *  sectionId       -  used in the data-od-id attribute (section-01 etc.)
 */
interface Props {
  sectionNumber: string;
  sectionTag: string;
  sectionMeta: string;
  sectionId: string;
  h2Label?: string;
}

const { sectionNumber, sectionTag, sectionMeta, sectionId, h2Label } = Astro.props;
---

<header class="section-bar" data-od-id={sectionId}>
  <div class="section-bar-inner">
    {h2Label && <h2 class="vh">{h2Label}</h2>}
    <div class="section">
      <span class="section-tag">{sectionTag}</span>
      <span>{sectionMeta}</span>
    </div>
  </div>
</header>
