---
/**
 * Tweaks panel. The bottom-right floating button + popover that lets
 * the visitor switch the active mark direction. Persists to
 * localStorage under "mark-direction".
 *
 * This component is presentational: it renders the four tiles. The
 * click handlers are bound by view-transitions.ts on every page
 * load so the tiles stay interactive across view transitions.
 */
import { marks } from "../data/marks";

interface Props {
  /** Initial direction to mark as pressed. Server-side default is "a". */
  initialDirection?: "a" | "b" | "c" | "d";
}

const { initialDirection = "a" } = Astro.props;
---

<div class="tweaks" data-od-id="tweaks-direction" transition:persist="tweaks">
  <div class="tweaks-panel" id="tweaks-panel" hidden>
    <div class="tweaks-head">
      <span class="tweaks-title">Mark</span>
      <span class="tweaks-sub">A / B / C / D</span>
    </div>
    <div class="tweaks-grid" role="radiogroup" aria-label="Identity mark direction">
      {marks.map((mark) => {
        const active = mark.id === initialDirection;
        return (
          <button
            type="button"
            class="tweaks-tile"
            data-set-direction={mark.id}
            aria-pressed={active ? "true" : "false"}
            aria-label={`Direction ${mark.id.toUpperCase()}: ${mark.name}`}
          >
            <svg viewBox="0 0 96 96" aria-hidden="true">
              {mark.id === "a" && (
                <>
                  <path
                    class="sg-accent"
                    d="M 16 22 L 80 22 Q 88 22 88 30 L 88 58 Q 88 66 80 66 L 36 66 L 24 78 L 24 66 L 16 66 Q 8 66 8 58 L 8 30 Q 8 22 16 22 Z"
                    fill="none"
                    stroke-width="3"
                    stroke-linejoin="round"
                  />
                  <circle class="fg-accent" cx="42" cy="44" r="5" />
                </>
              )}
              {mark.id === "b" && (
                <>
                  <rect class="fg-accent" x="12" y="8" width="72" height="80" rx="2" />
                  <text
                    class="fg-on mark-text-italic"
                    x="48"
                    y="64"
                    text-anchor="middle"
                    font-family="Newsreader, serif"
                    font-weight="500"
                    font-size="58"
                  >f</text>
                </>
              )}
              {mark.id === "c" && (
                <text
                  class="fg-ink mark-text-italic"
                  x="48"
                  y="80"
                  text-anchor="middle"
                  font-family="Newsreader, serif"
                  font-weight="400"
                  font-size="92"
                >f</text>
              )}
              {mark.id === "d" && (
                <>
                  <path
                    class="fg-accent"
                    d="M 14 18 L 54 18 Q 60 18 60 24 L 60 44 Q 60 50 54 50 L 30 50 L 22 58 L 22 50 L 14 50 Q 8 50 8 44 L 8 24 Q 8 18 14 18 Z"
                  />
                  <path
                    class="sg-ink"
                    d="M 42 46 L 82 46 Q 88 46 88 52 L 88 72 Q 88 78 82 78 L 74 78 L 74 86 L 66 78 L 42 78 Q 36 78 36 72 L 36 52 Q 36 46 42 46 Z"
                    fill="none"
                    stroke-width="3"
                    stroke-linejoin="round"
                  />
                </>
              )}
            </svg>
            <span class="tweaks-tile-label">{mark.name}</span>
          </button>
        );
      })}
    </div>
    <div class="tweaks-foot">
      <a class="tweaks-link" href="/identity" data-od-id="tweaks-link-identity">
        See all four
        <span aria-hidden="true">→</span>
      </a>
      <span class="tweaks-sub">saved locally</span>
    </div>
  </div>
  <button
    type="button"
    class="tweaks-toggle"
    id="tweaks-toggle"
    aria-expanded="false"
    aria-controls="tweaks-panel"
  >
    <span class="tweaks-toggle-dot" aria-hidden="true"></span>
    <span>Mark</span>
  </button>
</div>
