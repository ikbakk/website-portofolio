---
import type { Mark } from "../data/marks";

interface Props {
  mark: Mark;
  size?: 24 | 32 | 96 | 192;
  monogram?: string;
  labelled?: boolean;
}

const { mark, size = 32, labelled = false } = Astro.props;
const ariaLabel = labelled ? `Mark: ${mark.name}` : undefined;
---

<svg
  class:list={["mark", `mark-${mark.id}`]}
  viewBox="0 0 96 96"
  width={size}
  height={size}
  aria-hidden={labelled ? undefined : "true"}
  aria-label={ariaLabel}
  role={labelled ? "img" : undefined}
>
  <path
    class="sg-accent"
    d="M 16 22 L 80 22 Q 88 22 88 30 L 88 58 Q 88 66 80 66 L 36 66 L 24 78 L 24 66 L 16 66 Q 8 66 8 58 L 8 30 Q 8 22 16 22 Z"
    fill="none"
    stroke-width="2.5"
    stroke-linejoin="round"
  />
  <circle class="fg-accent" cx="42" cy="44" r="5" />
</svg>
