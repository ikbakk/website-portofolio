---
/**
 * Folio. The reusable section wrapper. Renders a sticky FolioBar
 * and a page-inner that carries the notebook grid background
 * (32px vertical, --fg at 4% mix, masked to fade 0 to 70%). The
 * FolioNumber sits in the bottom-right.
 *
 *  sectionNumber  -  the printed "01 / field note" string for the bottom-right
 *  sectionBarNumber  -  the printed "01" / "02" etc.
 *  sectionBarTag    -  the printed "01 / Field note" tag
 *  sectionBarMeta   -  the printed meta line
 *  sectionBarId     -  the data-od-id (section-01 etc.)
 *  sectionBarH2     -  optional screen-reader h2
 *  id             -  the field-note etc. id (used by the spine to scroll)
 *  odId           -  the data-od-id (field-note-hero etc.)
 */
import FolioBar from "./FolioBar.astro";
import FolioNumber from "./FolioNumber.astro";

interface Props {
  sectionNumber: string;
  sectionBarNumber: string;
  sectionBarTag: string;
  sectionBarMeta: string;
  sectionBarId: string;
  sectionBarH2?: string;
  id: string;
  odId: string;
}

const {
  sectionNumber,
  sectionBarNumber,
  sectionBarTag,
  sectionBarMeta,
  sectionBarId,
  sectionBarH2,
  id,
  odId,
} = Astro.props;
---

<article class="page" id={id} data-od-id={odId}>
  <FolioBar
    sectionNumber={sectionBarNumber}
    sectionTag={sectionBarTag}
    sectionMeta={sectionBarMeta}
    sectionId={sectionBarId}
    h2Label={sectionBarH2}
  />
  <div class="page-inner">
    <FolioNumber text={sectionNumber} />
    <slot />
  </div>
</article>
