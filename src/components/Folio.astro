---
interface Props { id: string; number: string; title: string; tone?: 'light' | 'dark'; }
const { id, number, title, tone = 'light' } = Astro.props;
---
<section id={id} class:list={['folio', tone === 'dark' && 'folio-dark']} data-section={id} data-motion="section">
  <div class="folio-pin">
    <span>{number}</span>
    <strong>{title}</strong>
  </div>
  <div class="folio-inner">
    <slot />
    <span class="folio-corner" aria-hidden="true">{number} / {title.toLowerCase()}</span>
  </div>
</section>
