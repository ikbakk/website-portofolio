---
import Folio from './Folio.astro';
import ProjectEntry from './ProjectEntry.astro';
import { projects, sectionCopy } from '../data/site';
---

<Folio id="work" number="02" title="Selected work">
  <div
    class="section-intro mb-[var(--space-14)] grid max-w-[58rem] gap-[var(--space-4)]"
    data-motion="intro"
  >
    <p
      class="eyebrow m-0 font-mono text-[var(--text-xs)] uppercase tracking-[var(--tracking-mono)] text-accent"
    >
      {sectionCopy.workEyebrow}
    </p>
    <h2
      class="m-0 max-w-[26ch] font-display text-[clamp(1.65rem,3vw,3rem)] font-medium leading-[1.02] tracking-[var(--tracking-display)] text-balance"
    >
      {sectionCopy.workTitle}
    </h2>
  </div>

  <ol
    class="m-0 grid list-none gap-[clamp(var(--space-14),14vw,var(--space-24))] p-0"
    aria-label="Selected projects"
    data-project-archive
  >
    {projects.map((project, index) => <ProjectEntry project={project} index={index} />)}
  </ol>

  <div
    class="pointer-events-none fixed left-0 top-0 z-[9999] aspect-[16/10] w-[clamp(14rem,26vw,23rem)] overflow-hidden rounded-[var(--radius-md)] border border-border bg-surface shadow-[var(--elev-raised)]"
    data-project-cursor-preview
    aria-hidden="true"
  >
    <img class="h-full w-full object-cover" data-project-cursor-image alt="" />
  </div>
</Folio>
