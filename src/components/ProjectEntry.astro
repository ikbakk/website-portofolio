---
const { project, index } = Astro.props;
const detailText = project.details.join('\n\n');
---
<article class="project-entry" data-motion="project" data-project-card data-project-index={index} tabindex="0">
  <aside class="project-meta">
    <span>{project.number} / {project.year}</span>
    <dl>
      <div><dt>Role</dt><dd>{project.role}</dd></div>
      <div><dt>Stack</dt><dd>{project.stack.join(' / ')}</dd></div>
      <div><dt>Outcome</dt><dd>{project.outcome}</dd></div>
    </dl>
  </aside>
  <div class="project-body">
    <div class="project-shot" data-state="empty" role="img" aria-label={`Screenshot slot for ${project.title}`}>
      <span>Screenshot pending</span>
      <small>Drop a 16:10 product capture into src/assets/projects.</small>
    </div>
    <div class="project-copy">
      <h3>{project.title}</h3>
      <p>{project.context}</p>
      <p>{project.contribution}</p>
      <footer>{project.note}</footer>
      <button
        class="button button-secondary project-detail-trigger"
        type="button"
        data-project-open
        data-project-index={index}
        data-project-number={project.number}
        data-project-year={project.year}
        data-project-title={project.title}
        data-project-role={project.role}
        data-project-stack={project.stack.join(' / ')}
        data-project-outcome={project.outcome}
        data-project-note={project.note}
        data-project-details={detailText}
      >
        View project details
      </button>
    </div>
  </div>
</article>
