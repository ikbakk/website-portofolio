---
/**
 * ProjectEntry. One project card. Renders the header (number,
 * title, meta dl), intro text, note, and a screenshot slot.
 *
 * Two layouts:
 *  - with-image:    a figure with <img> + caption leads the body.
 *  - without-image: text-only entry. No screenshot placeholder.
 *
 * The decision is data-driven: if `entry.image` is set, the
 * image-first layout is used; otherwise the text-first layout.
 *
 *  entry  -  ProjectSummary from src/data/projects
 *  The long-form markdown body (if any) is rendered through the
 *  default slot, so the page can pass `<Content />` from the
 *  content collection.
 */
import type { ProjectSummary } from "../data/projects";

interface Props {
  entry: ProjectSummary;
}

const { entry } = Astro.props;
const hasImage = Boolean(entry.image);
---

<article
  class:list={["project", hasImage && "project--with-image"]}
  data-od-id={`entry-${entry.number}`}
  data-od-reveal="scroll"
>
  <div class="project-head">
    <div class="project-number">{entry.number} / {entry.year}</div>
    <h2 class="project-title">{entry.title}</h2>
    <div class="project-meta">
      <dl>
        <dt>Role</dt>
        <dd>{entry.role}</dd>
        <dt>Stack</dt>
        <dd>{entry.stack}</dd>
        <dt>Team</dt>
        <dd>{entry.team}</dd>
        <dt>Outcome</dt>
        <dd>{entry.outcome}</dd>
      </dl>
    </div>
  </div>
  <div class="project-body">
    {hasImage && (
      <figure class="project-figure" data-od-id={`entry-${entry.number}-figure`}>
        <img
          class="project-image"
          src={entry.image!.src}
          alt={entry.image!.alt}
          loading="lazy"
        />
        {entry.image!.caption && (
          <figcaption class="project-caption">{entry.image!.caption}</figcaption>
        )}
      </figure>
    )}

    <p class="project-intro">{entry.lede}</p>
    <slot />

    <div class="project-notes">
      <span class="note-title">{entry.noteLabel}</span>
      {entry.note}
    </div>
  </div>
</article>
