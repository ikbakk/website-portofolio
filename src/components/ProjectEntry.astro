---
/**
 * ProjectEntry. One project card. Renders the header (number,
 * title, meta dl), intro text, note, and screenshot slot.
 *
 *  entry  -  ProjectSummary from src/data/projects
 *  The long-form markdown body (if any) is rendered through the
 *  default slot, so the page can pass `<Content />` from the
 *  content collection.
 */
import type { ProjectSummary } from "../data/projects";

interface Props {
  entry: ProjectSummary;
}

const { entry } = Astro.props;
---

<article class="project" data-od-id={`entry-${entry.number}`} data-od-reveal="scroll">
  <div class="project-head">
    <div class="project-number">{entry.number} / {entry.year}</div>
    <h2 class="project-title">{entry.title}</h2>
    <div class="project-meta">
      <dl>
        <dt>Role</dt>
        <dd>{entry.role}</dd>
        <dt>Stack</dt>
        <dd>{entry.stack}</dd>
        <dt>Team</dt>
        <dd>{entry.team}</dd>
        <dt>Outcome</dt>
        <dd>{entry.outcome}</dd>
      </dl>
    </div>
  </div>
  <div class="project-body">
    <p class="project-intro">{entry.lede}</p>
    <slot />

    <div class="project-notes">
      <span class="note-title">{entry.noteLabel}</span>
      {entry.note}
    </div>

    <div
      class="project-visual"
      data-od-id={`entry-${entry.number}-visual`}
      data-state="empty"
      role="img"
      aria-label={`Screenshot slot for project ${entry.number}, awaiting asset`}
    >
      <span>Screenshot / mockup, 16:10</span>
      <span class="screenshot-hint">
        Drop a screenshot here once the project is chosen. The slot holds a 16:10 ratio.
      </span>
    </div>
  </div>
</article>
